# =============================================================================
# Root .env — Docker Compose Infrastructure Variables
# =============================================================================
# Copy: cp .env.example .env  then fill values
# This file is read by docker-compose.yml for shared infrastructure config
# =============================================================================

# Database
DB_USER=erp_user
DB_PASSWORD=<CHANGE_THIS>
DB_NAME=erp_db

# Redis
REDIS_PASSWORD=<CHANGE_THIS>

# Docker Hub (for CI/CD image pulling)
DOCKERHUB_USERNAME=yourdockerhubusername
IMAGE_TAG=latest

# Frontend public URL (used during build)
VITE_API_URL=
