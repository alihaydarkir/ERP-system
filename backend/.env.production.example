# =============================================================================
# ERP System — Production Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.production.example .env
#   2. Fill in every value marked with <CHANGE_THIS>
#   3. NEVER commit the real .env file to git (it's in .gitignore)
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# In Docker Compose, DB_HOST is automatically set to "postgres" (service name)
# The DATABASE_URL is also overridden by docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_USER=erp_user
DB_PASSWORD=<CHANGE_THIS_use_openssl_rand_base64_32>
DB_NAME=erp_db
DATABASE_URL=postgresql://erp_user:<DB_PASSWORD>@postgres:5432/erp_db

# ── Redis ──────────────────────────────────────────────────────────────────
# In Docker Compose, REDIS_URL is automatically set from REDIS_PASSWORD env var
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# ── JWT (CRITICAL: use strong random secrets) ──────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CHANGE_THIS_minimum_64_chars_random_hex>
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS (comma-separated allowed origins) ────────────────────────────────
# Add your domain(s) here
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
STRICT_ORIGIN_CHECK=true

# ── Frontend URL (used in emails, health endpoint) ────────────────────────
FRONTEND_URL=https://yourdomain.com

# ── Email (SendGrid or SMTP) ──────────────────────────────────────────────
# Option A: SMTP (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<CHANGE_THIS>@gmail.com
SMTP_PASSWORD=<CHANGE_THIS_app_password>
SMTP_FROM=noreply@yourdomain.com

# Option B: SendGrid
# SENDGRID_API_KEY=<CHANGE_THIS>

# ── AI — Ollama (local, on same host or separate container) ───────────────
# If Ollama runs on the host machine (not in Docker):
OLLAMA_BASE_URL=http://host.docker.internal:11434
# If Ollama runs in its own Docker container:
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5

# Optional: OpenAI for hybrid AI (general queries)
# OPENAI_API_KEY=<CHANGE_THIS>
# OPENAI_MODEL=gpt-4o-mini

# ── AI/RAG settings ────────────────────────────────────────────────────────
AI_MAX_CONTEXT=2000
RAG_TOP_K=5
RAG_THRESHOLD=0.7

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FORMAT=json   # Use JSON format for log aggregators (Datadog, Loki, etc.)

# ── File Uploads ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_PATH=/app/uploads

# ── Security ────────────────────────────────────────────────────────────────
# These are used by the security middleware
SESSION_SECRET=<CHANGE_THIS_use_openssl_rand_base64_32>
ENCRYPTION_KEY=<CHANGE_THIS_32_byte_hex>

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per 15 min per IP (production default: 100)
RATE_LIMIT_MAX=100

# =============================================================================
# ROOT-LEVEL .env (docker-compose reads these for service configuration)
# These must also be set in the root .env file for docker-compose
# =============================================================================
# DB_USER=erp_user
# DB_PASSWORD=<same as above>
# DB_NAME=erp_db
# REDIS_PASSWORD=<CHANGE_THIS>
# DOCKERHUB_USERNAME=yourdockerhubusername
# IMAGE_TAG=latest
